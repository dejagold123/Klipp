# Required
OPENAI_API_KEY=sk-...

# Optional - set to your deployment's public URL so clip download_url fields are absolute
# e.g. https://your-deployment.example.com
KLIPP_BASE_URL=

# Optional - set a random secret to protect your API from unauthorized use
# e.g. openssl rand -hex 32
KLIPP_API_KEY=

# Storage paths (set automatically if deploying via Railway/nixpacks.toml;
# set manually otherwise)
KLIPP_CLIPS_DIR=/data/clips
KLIPP_WORK_DIR=/tmp/klipp

# Optional - override the deployment-wide default provider (per-request
# stt_provider/llm_provider always wins over these). Defaults to "openai".
# STT options: openai, vosk, wav2vec
# LLM options: openai, mistral, llama, phi, local
DEFAULT_STT_PROVIDER=openai
DEFAULT_LLM_PROVIDER=openai

# Required only if you set llm_provider/DEFAULT_LLM_PROVIDER to "mistral"
MISTRAL_API_KEY=

# Required only if you set llm_provider/DEFAULT_LLM_PROVIDER to "llama"
# Path to a local GGUF model file - not bundled, you supply this yourself
LLAMA_MODEL_PATH=./models/llama-2-7b-chat.gguf

# Optional - master switch for webhook notifications on job completion/failure
PHAROS_ENABLED=true

# Optional - default webhook target used when a request doesn't supply its
# own webhook_url. Leave blank to disable by default.
PHAROS_WEBHOOK_URL=

# Set this to wherever your Redis instance lives. If deploying via Railway
# with a Redis plugin added, this is injected automatically - don't set it
# manually in that case.
# REDIS_URL=redis://...
